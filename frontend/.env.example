# For local development (default — no change needed):
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# For HuggingFace Spaces deployment, replace with your Space URL:
# Format: https://<your-hf-username>-<space-name>.hf.space
# Example:
# NEXT_PUBLIC_API_URL=https://yourname-ayurfit-backend.hf.space
